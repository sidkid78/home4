# Required. Prisma/PostgreSQL connection strings.
#
# Local dev (Supabase CLI or plain Postgres) — a single URL is enough; DIRECT_URL
# can mirror DATABASE_URL:
#   DATABASE_URL="postgresql://postgres:postgres@localhost:54322/postgres?schema=homease"
#   DIRECT_URL="postgresql://postgres:postgres@localhost:54322/postgres?schema=homease"
#
# Hosted Supabase — use the SUPAVISOR POOLER (IPv4-reachable), NOT the direct
# db.<ref>.supabase.co host (IPv6-only). Grab both from the dashboard Connect panel.
# Percent-encode special chars in the password (e.g. % -> %25, @ -> %40).
#   DATABASE_URL="postgresql://postgres.<ref>:<pwd>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true"
#   DIRECT_URL="postgresql://postgres.<ref>:<pwd>@aws-0-<region>.pooler.supabase.com:5432/postgres"
DATABASE_URL="postgresql://postgres:postgres@localhost:54322/postgres?schema=homease"
DIRECT_URL="postgresql://postgres:postgres@localhost:54322/postgres?schema=homease"

# Optional. Absent -> AIEngineService returns deterministic mock assessments.
GEMINI_API_KEY=

# Optional. Absent -> queues plugin uses an in-memory no-op queue instead of BullMQ.
REDIS_URL=

# Optional. Defaults to "sk_test_mock" -> Stripe calls are stubbed with fake URLs/session IDs.
STRIPE_API_KEY=
# Optional. Gates Stripe webhook signature verification.
STRIPE_WEBHOOK_SECRET=

# Optional. Used by @fastify/jwt and to sign JSON-LD property certificates. Defaults to "supersecret".
JWT_SECRET=

# Optional. Redirect base for Stripe onboarding/checkout. Defaults to http://localhost:3000.
FRONTEND_URL=

# Frontend (Vite) — client-safe Supabase Storage upload creds (exposed in the browser).
# Absent -> useSupabaseUpload falls back to mock:// URLs (AI runs in mock mode).
# On Vercel these must also be set as project env vars (baked into the build).
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=

# Optional. Dev bootstrap/settlement routes (/v1/dev/*) are ON outside production
# and OFF in production unless this is "true". Set to "true" in a hosted preview
# to run the public demo (the frontend needs /v1/dev/demo-property); leave unset
# for a real deployment.
ENABLE_DEV_ROUTES=
